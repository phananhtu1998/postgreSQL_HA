# =====================================================================
#  PostgreSQL HA — environment template.
#  Copy to .env and replace every "ChangeMe*" with strong random values.
#  Generate good passwords with:  openssl rand -base64 32
# =====================================================================

# ─── Cluster identity ─────────────────────────────────────────────
# Logical cluster name stored in etcd (/service/<scope>).
PATRONI_SCOPE=pgcluster

# ─── Postgres superuser (Patroni manages this account) ────────────
PATRONI_SUPERUSER_NAME=postgres
PATRONI_SUPERUSER_PASSWORD=123

# ─── Replication user (used between Patroni nodes) ────────────────
PATRONI_REPLICATION_USERNAME=replicator
PATRONI_REPLICATION_PASSWORD=rep123

# ─── Patroni REST API auth (used by HAProxy /leader, /replica) ────
PATRONI_REST_USER=patroni_rest
PATRONI_REST_PASSWORD=api123

# ─── Application database & user ──────────────────────────────────
APP_DB_NAME=thaco
APP_DB_USER=dev
APP_DB_PASSWORD=Thaco1234

ADMIN_DB_USER=admin
ADMIN_DB_PASSWORD=123

# Các database bổ sung mà PgBouncer sẽ định tuyến (mỗi DB sinh 3 alias:
# <db>, <db>_rw, <db>_ro). Bạn vẫn phải tự CREATE DATABASE trên Postgres
# leader trước. Chỉ chấp nhận ký tự [a-zA-Z0-9_]. Restart pgbouncer
# sau khi đổi giá trị này: `docker compose up -d --force-recreate pgbouncer`.
# Ví dụ: APP_DBS_EXTRA=shop_db,billing_db,analytics_db
#
# LƯU Ý: nếu bật pgbouncer-autosync (mặc định ON), bạn KHÔNG cần khai
# báo APP_DBS_EXTRA cho mỗi DB mới — sidecar sẽ tự discover. Biến này
# chỉ còn hữu ích khi muốn pre-route 1 DB chưa tồn tại trong Postgres.
APP_DBS_EXTRA=

# ─── PgBouncer auto-sync sidecar ──────────────────────────────────
# Tự động phát hiện DB mới được tạo trong Postgres (qua pgAdmin/psql/
# code) và cập nhật pgbouncer.ini + RELOAD online — không cần
# force-recreate, không disconnect client.
#
# true (mặc định)  → bật sidecar, poll mỗi PGBOUNCER_AUTOSYNC_INTERVAL giây.
# false            → tắt; sidecar container vẫn chạy nhưng sleep infinity.
PGBOUNCER_AUTOSYNC_ENABLED=true

# Chu kỳ poll pg_database (giây). 5s cho dev (phản hồi nhanh khi tạo DB
# mới từ pgAdmin/code). Production có thể tăng lên 30–60s để giảm tải.
PGBOUNCER_AUTOSYNC_INTERVAL=5

# Bỏ qua các DB này khi phát hiện. Mặc định loại postgres + 2 template.
# Có thể thêm DB nội bộ không muốn expose qua PgBouncer, vd:
#   PGBOUNCER_AUTOSYNC_EXCLUDE=postgres,template0,template1,internal_metrics
PGBOUNCER_AUTOSYNC_EXCLUDE=postgres,template0,template1

# Số giây sidecar đợi sau khi start trước khi poll lần đầu — cho
# pgbouncer container kịp render pgbouncer.ini.
PGBOUNCER_AUTOSYNC_INITIAL_DELAY=5

# ─── Redis Sentinel HA ────────────────────────────────────────────
# 1 master + 2 replicas + 3 sentinels (quorum 2).
# Sentinel-aware clients discover the current master automatically.
# Tất cả node Redis nằm chung network pg-ha với PostgreSQL.

# Password cho Redis nodes (master + replicas). Dùng openssl rand -base64 32.
REDIS_PASSWORD=CHANGE_ME

# Password cho Sentinel nodes (client phải AUTH để query sentinel).
REDIS_SENTINEL_PASSWORD=CHANGE_ME

# Memory limit cho mỗi Redis node.
REDIS_MAXMEMORY=512mb

# Thời gian sentinel đợi trước khi đánh dấu master down (ms).
# Production: 10000–30000 (mạng nhiễu); 5000 cho in-DC.
REDIS_SENTINEL_DOWN_AFTER_MS=5000

# Tổng deadline cho failover (ms).
REDIS_SENTINEL_FAILOVER_TIMEOUT_MS=30000

# Số replica được reconfig song song sau promote (1 = an toàn nhất).
REDIS_SENTINEL_PARALLEL_SYNCS=1

# Quorum: tối thiểu sentinel đồng ý master down. Luôn (N/2)+1.
REDIS_SENTINEL_QUORUM=2

# Tên sentinel group (master name). Client dùng tên này để discover master.
# Mặc định "mymaster". Đổi nếu muốn tên dễ nhận biết hơn, ví dụ: redisthaco.
REDIS_SENTINEL_MASTER_NAME=mymaster

# Replica priority — thấp hơn = ưu tiên promote (0 = không bao giờ).
REDIS_REPLICA_1_PRIORITY=100
REDIS_REPLICA_2_PRIORITY=90

# ─── Announce IP cho kết nối ngoài Docker ───────────────────────
# Chỉ cần set nếu sentinel-aware client chạy NGOÀI Docker network
# (ví dụ: app trên Windows/Mac kết nối qua IP server).
# Khi set, sentinel sẽ trả về IP này thay vì hostname nội bộ Docker.
#
# REDIS_ANNOUNCE_IP: dùng cho redis-master và replicas.
# REDIS_SENTINEL_ANNOUNCE_IP: dùng cho sentinel nodes.
# Thường cả 2 đều là IP của server chạy Docker.
# Ví dụ: REDIS_ANNOUNCE_IP=10.14.80.7
REDIS_ANNOUNCE_IP=
REDIS_SENTINEL_ANNOUNCE_IP=

# ─── Redis port bindings ─────────────────────────────────────────
REDIS_MASTER_PORT=6379
REDIS_REPLICA_1_PORT=6380
REDIS_REPLICA_2_PORT=6381
REDIS_SENTINEL_1_PORT=26379
REDIS_SENTINEL_2_PORT=26380
REDIS_SENTINEL_3_PORT=26381

# ─── Health-check role (HAProxy probes via PgBouncer auth_query) ──
PG_HEALTHCHECK_USER=health_chk
PG_HEALTHCHECK_PASSWORD=ChangeMe_StrongHealthcheckPassword

# ─── HAProxy stats UI ─────────────────────────────────────────────
HAPROXY_STATS_PASSWORD=ha123

# ─── PgBouncer tuning ─────────────────────────────────────────────
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=80
PGBOUNCER_RESERVE_POOL_SIZE=20

# ─── pgBackRest stanza name ───────────────────────────────────────
PGBACKREST_STANZA=main

# ─── Backup overlay ───────────────────────────────────────────────
BACKUP_CRON_FULL="0 2 * * 0"        # weekly full backup, Sun 02:00
BACKUP_CRON_INCR="0 2 * * 1-6"      # daily incremental, Mon-Sat 02:00

# pgBackRest performance and retention.
PGBACKREST_PROCESS_MAX=2
PGBACKREST_COMPRESS_TYPE=zst
PGBACKREST_COMPRESS_LEVEL=3
PGBACKREST_REPO1_RETENTION_FULL=2
PGBACKREST_REPO1_RETENTION_DIFF=4
PGBACKREST_REPO2_RETENTION_FULL=7
PGBACKREST_REPO2_RETENTION_DIFF=14

# ─── Monitoring overlay ───────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=123

# ─── Dev overlay (pgAdmin + Redis Insight) ───────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=123
PGADMIN_HOST=0.0.0.0
PGADMIN_PORT=8080
PGADMIN_SERVER_MODE=True

# Redis Insight — GUI quản trị Redis (browser-based).
# Mặc định bind 127.0.0.1; set REDIS_INSIGHT_HOST=0.0.0.0 để truy cập từ ngoài.
REDIS_INSIGHT_HOST=0.0.0.0
REDIS_INSIGHT_PORT=5540
# ─── Host port overrides (set if defaults clash on your host) ─────
PG_1_PORT=54321
PG_2_PORT=54322
PG_3_PORT=54323
PATRONI_1_REST_PORT=8011
PATRONI_2_REST_PORT=8012
PATRONI_3_REST_PORT=8013
HAPROXY_WRITE_PORT=5000
HAPROXY_READ_PORT=5001
HAPROXY_STATS_PORT=7000
PGBOUNCER_PORT=6432

# MinIO overlay (S3-compatible pgBackRest repo2)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

PGBACKREST_S3_KEY=pgbackrest
PGBACKREST_S3_KEY_SECRET=thaco@123
PGBACKREST_S3_BUCKET=pgbackrest
PGBACKREST_S3_REGION=us-east-1
PGBACKREST_S3_PATH=/pgbackrest
PGBACKREST_S3_ENDPOINT=minio:9000
PGBACKREST_S3_URI_STYLE=path
PGBACKREST_S3_VERIFY_TLS=n
PGBACKREST_REPO2_CIPHER_TYPE=aes-256-cbc
PGBACKREST_REPO2_CIPHER_PASS=thaco@123

# Backup/restore repository selector:
#   repo1 = local Docker volume, useful for fast local restore.
#   repo2 = MinIO/S3 object storage, recommended primary production backup.
BACKUP_REPO=1
RESTORE_REPO=1

# Cron can write to one or more repos. Local/dev can use "1".
# Production with external MinIO/S3 should usually use "2" or "1,2".
BACKUP_REPOS=1
