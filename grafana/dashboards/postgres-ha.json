{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "schemaVersion": 39,
  "tags": ["postgres", "ha"],
  "title": "Postgres HA Overview",
  "uid": "postgres-ha",
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "PG Up",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "pg_up", "legendFormat": "{{instance}}"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}}}
    },
    {
      "id": 2, "type": "stat", "title": "Role (1=primary, 0=replica)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "1 - pg_replication_is_replica", "legendFormat": "{{instance}}"}]
    },
    {
      "id": 3, "type": "timeseries", "title": "Active Connections",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "sum by (instance) (pg_stat_activity_count)", "legendFormat": "{{instance}}"}]
    },
    {
      "id": 4, "type": "timeseries", "title": "Replication Lag (s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "pg_replication_lag_seconds", "legendFormat": "{{instance}}"}]
    },
    {
      "id": 5, "type": "timeseries", "title": "Transactions / sec (commit + rollback)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "rate(pg_stat_database_xact_commit{datname!~\"template.*\"}[5m])", "legendFormat": "{{instance}} {{datname}} commit"},
        {"expr": "rate(pg_stat_database_xact_rollback{datname!~\"template.*\"}[5m])", "legendFormat": "{{instance}} {{datname}} rollback"}
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Cache Hit Ratio (%)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{"expr": "100 * sum by (instance) (rate(pg_stat_database_blks_hit[5m])) / clamp_min(sum by (instance) (rate(pg_stat_database_blks_hit[5m])) + sum by (instance) (rate(pg_stat_database_blks_read[5m])), 1)", "legendFormat": "{{instance}}"}]
    },
    {
      "id": 7, "type": "timeseries", "title": "Database Size (bytes)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [{"expr": "pg_database_size_bytes{datname!~\"template.*\"}", "legendFormat": "{{instance}} {{datname}}"}]
    },
    {
      "id": 8, "type": "timeseries", "title": "Deadlocks /s",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [{"expr": "rate(pg_stat_database_deadlocks{datname!~\"template.*\"}[5m])", "legendFormat": "{{instance}} {{datname}}"}]
    }
  ]
}
